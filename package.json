{
  "name": "codechat-docs",
  "version": "0.0.4",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "next build",
    "prebuild": "pnpm sync:docs && pnpm generate:webhooks && pnpm audit:api && pnpm validate:openapi && pnpm generate:search && pnpm validate:content",
    "dev": "next dev",
    "predev": "pnpm sync:docs && pnpm generate:webhooks && pnpm generate:search",
    "start": "next start",
    "typecheck": "fumadocs-mdx && next typegen && tsc --noEmit",
    "types:check": "pnpm typecheck",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "sync:docs": "node scripts/sync-source-docs.mjs",
    "generate:webhooks": "node scripts/generate-webhook-catalog.mjs",
    "generate:search": "node scripts/generate-search-index.mjs",
    "generate:search-index": "pnpm generate:search",
    "audit:api": "node scripts/audit-api-reference.mjs",
    "validate:routes": "node scripts/audit-api-reference.mjs",
    "validate:openapi": "redocly lint public/openapi.yml",
    "validate:content": "node scripts/validate-content.mjs",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "cnfast": "^0.0.8",
    "fumadocs-core": "16.11.3",
    "fumadocs-mdx": "15.1.0",
    "fumadocs-ui": "npm:@fumadocs/base-ui@16.11.3",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "openapi-types": "^12.1.3",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@redocly/cli": "^2.38.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
